<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BloodStrike Anti Cheat Vulnerability Research — MattRWX</title>
    <link rel="stylesheet" href="../style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        background: 'hsl(220 20% 4%)',
                        foreground: 'hsl(270 60% 90%)',
                        primary: 'hsl(270 91% 65%)',
                        secondary: 'hsl(220 16% 12%)',
                        card: 'hsl(220 18% 7%)',
                        muted: 'hsl(220 14% 10%)',
                        'muted-foreground': 'hsl(220 10% 50%)',
                        accent: 'hsl(270 95% 75%)',
                        border: 'hsl(270 30% 18%)',
                        'terminal-dim': 'hsl(270 15% 35%)',
                    }
                }
            }
        }
    </script>
</head>

<body
    class="bg-background text-foreground min-h-screen flex flex-col items-center relative overflow-x-hidden font-['Space_Grotesk']">

    <div class="grid-background fixed inset-0 z-0 pointer-events-none overflow-hidden">
        <div
            class="absolute inset-0 z-10 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(0,0,0,0.6)_30%,#000_75%)]">
        </div>
        <svg class="absolute w-full h-full opacity-20" viewBox="0 0 960 637" fill="none"
            xmlns="http://www.w3.org/2000/svg">
            <g stroke="white" stroke-opacity="0.1" stroke-width="0.5">
                <line x1="123.5" y1="0" x2="123.5" y2="637" />
                <line x1="202.5" y1="0" x2="202.5" y2="637" />
                <line x1="281.5" y1="0" x2="281.5" y2="637" />
                <line x1="360.5" y1="0" x2="360.5" y2="637" />
                <line x1="439.5" y1="0" x2="439.5" y2="637" />
            </g>
        </svg>
    </div>

    <div class="relative z-10 w-full max-w-[50rem] mx-auto px-6 py-16">
        <header class="mb-12">
            <div class="flex items-center gap-4 mb-2">
                <a href="blogs.html" class="text-primary hover:text-accent transition-colors font-mono text-sm">←
                    BACK_TO_BLOGS</a>
            </div>
            <h1 class="text-4xl font-bold tracking-tight text-foreground font-mono mb-4">Custom Page Tables</h1>
            <div class="flex items-center gap-4 text-xs font-mono text-terminal-dim">
                <span>AUTHOR: Matthew Dominguez</span>
                <span>•</span>
                <span>DATE: March 17, 2026</span>
            </div>
            <div class="h-1 w-20 bg-primary mt-6 rounded-full"></div>
        </header>

        <main
            class="prose prose-invert prose-purple max-w-none font-mono text-[0.95rem] leading-relaxed text-secondary-foreground space-y-6">
            <p>
                Test
            </p>
        </main>

        <footer class="mt-20 border-t border-border pt-10 text-center space-y-4">
            <a href="blogs.html"
                class="inline-block text-primary hover:text-accent transition-colors font-mono text-sm underline decoration-primary/30 underline-offset-4">RETURN_TO_ARCHIVE.EXE</a>
            <div class="font-mono text-[10px] text-terminal-dim">
                © 2026 matt · Memory Architecture Series
            </div>
        </footer>
    </div>
</body>

</html>
